# ========================================
# Fantasy12 API - Environment Variables
# ========================================

# --- Core ---
NODE_ENV=development
PORT=3001

# --- Database ---
DATABASE_URL=postgresql://fantasy12:fantasy12@localhost:5432/fantasy12?schema=public
RUN_DB_MIGRATIONS=false

# --- Auth & Sessão ---
SESSION_SECRET=change-me-min-32-chars
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
# Renova o TTL a cada requisicao ativa (default: 30 min)
SESSION_IDLE_TTL_MIN=30
# Limite maximo mesmo com atividade continua (default: 24 h)
SESSION_ABSOLUTE_TTL_HOURS=24

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Email / Recuperacao de senha ---
# Em producao, sem EMAIL_PROVIDER real o endpoint de recuperacao responde generico,
# mas nao gera token nem envia link.
# Provider suportado atualmente: smtp
EMAIL_PROVIDER=
EMAIL_FROM=Fantasy12 <no-reply@fantasy12.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- Internal Jobs ---
INTERNAL_JOB_SECRET=change-me-too

# --- Sessões compartilhadas / BullMQ ---
# Obrigatorio para API e worker. Sessoes usam prefixo f12:session:;
# filas continuam isoladas por BULLMQ_PREFIX.
REDIS_URL=redis://:change-me@localhost:6379/0
# Prefix isolates queues between environments (dev/test/prod)
BULLMQ_PREFIX=fantasy12-dev
BULLMQ_WORKER_CONCURRENCY=1
# Set false only for a secondary worker that should not upsert schedules
BULLMQ_REGISTER_SCHEDULES=true
WORKER_HEALTH_PORT=3002

# --- Mercado Pago ---
# Token de acesso da aplicação (obrigatório para criar/consultar pagamentos)
MP_ACCESS_TOKEN=
# Chave pública para checkout no frontend
MP_PUBLIC_KEY=
# Secret usado para validar assinatura HMAC dos webhooks
# (configurado em https://www.mercadopago.com.br/developers > Webhooks)
MP_WEBHOOK_SECRET=
# Assinatura secreta da aba Modo de teste, quando diferente da producao
MP_TEST_WEBHOOK_SECRET=
# Permite webhook sem assinatura apenas em sandbox com MP_ACCESS_TOKEN=TEST-...
MP_ALLOW_UNSIGNED_TEST_WEBHOOKS=false
# Janela maxima aceita para assinatura de webhook moderno (default: 300s)
MP_WEBHOOK_MAX_AGE_SECONDS=300
# URL publica da API usada para montar notification_url do Mercado Pago
API_PUBLIC_URL=http://localhost:3001
# Se precisar sobrescrever diretamente a URL de webhook enviada ao MP
MP_NOTIFICATION_URL=
# URL base da API do MP - use https://api.mercadopago.com para produção
# ou aponte para sandbox quando aplicável
MP_API_BASE_URL=https://api.mercadopago.com
# Use true apenas se quiser forçar sandbox_init_point legado
MP_USE_SANDBOX_INIT_POINT=false

# --- Logging / Observabilidade ---
LOG_LEVEL=info
OPERATIONS_ALERT_WEBHOOK_URL=

# --- Backup / Restore ---
# Diretorio local para backups gerados manualmente pelo script
BACKUP_DIR=backups/postgres
# Retencao operacional documentada no manifest
BACKUP_RETENTION=daily-7 weekly-4 monthly-3
# Comando opcional para enviar backup e manifest a armazenamento externo.
# Exemplos:
# BACKUP_UPLOAD_COMMAND=rclone copy "{file}" remote:f12-backups/postgres && rclone copy "{manifest}" remote:f12-backups/postgres
# BACKUP_UPLOAD_COMMAND=aws s3 cp "{file}" s3://bucket/f12/postgres/ && aws s3 cp "{manifest}" s3://bucket/f12/postgres/
BACKUP_UPLOAD_COMMAND=
# URL de banco descartavel/alvo para restore testado. Nunca apontar para producao sem confirmacao operacional.
RESTORE_DATABASE_URL=

# --- Rate Limiting ---
# Máximo de requisições por IP em uma janela (default: 100/min)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
# Limites especificos para rotas internas que nao passam pelo limiter global
RATE_LIMIT_WEBHOOK_MAX=240
RATE_LIMIT_LEGACY_WEBHOOK_MAX=30
RATE_LIMIT_INTERNAL_JOB_MAX=60
